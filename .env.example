# Environment variables for BookMePro
# Copy this file to .env.local and replace placeholder values.

# =========================
# Database
# =========================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bookmepro?retryWrites=true&w=majority
MONGODB_DB=bookmepro

# =========================
# Auth and session
# =========================
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Google OAuth (NextAuth)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Calendar (can use the login OAuth client, but a dedicated web client
# is preferred in production so Calendar scopes and redirect URIs are isolated)
GOOGLE_CALENDAR_CLIENT_ID=your-calendar-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-calendar-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes
GOOGLE_CALENDAR_STATE_SECRET=replace-with-a-long-random-secret
GOOGLE_CALENDAR_WEBHOOK_URL=https://example.com/api/webhooks/google-calendar

# =========================
# Stripe
# =========================
# Primary secret key used by most routes.
STRIPE_SECRET_KEY=sk_test_replace_with_your_key

# Legacy fallback key still supported by some scripts/helpers.
# Keep this in sync with STRIPE_SECRET_KEY or leave empty.
STRIPE_SECRET=

STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

# Pricing refs can be env vars in this project.
# Checkout resolves Stripe Price IDs dynamically via lookup_key using:
#   {plan}_{billingCycle}_{countryCode} (lowercase)
# Example: starter_monthly_au, growth_yearly_default
# Ensure those lookup keys exist on Stripe Price objects.

# =========================
# Email (Brevo)
# =========================
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_EMAIL=notifications@example.com
BREVO_SENDER_NAME=BookMePro
BREVO_WEBHOOK_SECRET=replace-with-a-long-random-secret
CONTACT_RECIPIENT_EMAIL=admin@example.com

# =========================
# Vercel Cron
# =========================
# Set this in Vercel production. Vercel sends it as:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-cron-secret

# =========================
# Cloudinary uploads
# =========================
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =========================
# Public app URLs
# =========================
# Used by frontend and API routes when constructing absolute URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Legacy fallback still used in some dashboard components.
# Use a full origin (with protocol), not just a hostname.
NEXT_PUBLIC_DOMAIN=http://localhost:3000

# Used by metadata, sitemap, and robots host/canonical values.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Next.js runtime mode
NODE_ENV=development
